{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["FF_*", "FEATURE_FLAGS_JSON"],
  "tasks": {
    "//#changelog:aggregate": {
      "inputs": [
        "changelog/entries/**/*.md",
        "packages/changelog-generator/src/**/*.ts"
      ],
      "outputs": ["src/data/changelog.json"],
      "cache": true
    },
    "//#recipes:compile": {
      "inputs": [
        "docs/cookbook/**/*.mdx",
        "src/types/recipe.ts",
        "scripts/compile-recipes.ts"
      ],
      "outputs": ["src/data/recipes.json"],
      "cache": true
    },
    "//#generate:rss": {
      "dependsOn": ["//#changelog:aggregate"],
      "inputs": [
        "src/data/changelog.json",
        "packages/changelog-generator/src/**/*.ts"
      ],
      "outputs": ["static/changelog.xml"],
      "cache": true
    },
    "//#docusaurus:build": {
      "dependsOn": [
        "//#changelog:aggregate",
        "//#generate:rss",
        "//#recipes:compile"
      ],
      "inputs": [
        "docs/**",
        "src/**",
        "static/**",
        "docusaurus.config.ts",
        "sidebars.ts",
        "package.json"
      ],
      "outputs": ["build/**"],
      "cache": true
    },
    "//#test": {
      "outputs": [],
      "cache": true
    },
    "//#prepare-dev": {
      "dependsOn": [
        "//#changelog:aggregate",
        "//#generate:rss",
        "//#recipes:compile"
      ],
      "outputs": [
        "src/data/changelog.json",
        "static/changelog.xml",
        "src/data/recipes.json"
      ],
      "cache": true
    },
    "//#dev": {
      "dependsOn": ["//#prepare-dev"],
      "cache": false,
      "persistent": true
    }
  }
}
