{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["node_modules/@gleanwork/web-sdk/types/index.d.ts"],
  "tsconfig": "scripts/typedoc/tsconfig.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "docs/libraries/web-sdk/reference",
  "name": "Web SDK Reference",
  "readme": "none",
  "disableSources": true,
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true,
  "enumMembersFormat": "table",
  "parametersFormat": "table",
  "propertiesFormat": "list",
  "typeDeclarationFormat": "table",
  "indexFormat": "table",
  "entryFileName": "index",
  "cleanOutputDir": true
}
